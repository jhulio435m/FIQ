# Copy to .env on each node. Do not commit real .env files.

# Node identity. Use one of:
# - oti: NODE_ID=1, ETCD_NAME=etcd-1, PATRONI_NAME=oti, NODE_IP=100.79.244.99
# - ubuntu: NODE_ID=2, ETCD_NAME=etcd-2, PATRONI_NAME=ubuntu, NODE_IP=100.97.171.89
# - laptop: NODE_ID=3, ETCD_NAME=etcd-3, PATRONI_NAME=laptop, NODE_IP=100.126.122.28
NODE_ID=1
NODE_IP=100.79.244.99
ETCD_NAME=etcd-1
PATRONI_NAME=oti

# Cluster node addresses over the private network used by PostgreSQL HA.
NODE1_IP=100.79.244.99
NODE2_IP=100.97.171.89
NODE3_IP=100.126.122.28

ETCD_INITIAL_CLUSTER_TOKEN=fiq-etcd-cluster
ETCD_INITIAL_CLUSTER=etcd-1=http://100.79.244.99:2380,etcd-2=http://100.97.171.89:2380,etcd-3=http://100.126.122.28:2380
ETCD_INITIAL_CLUSTER_STATE=new
PATRONI_ETCD3_HOSTS=100.79.244.99:2379,100.97.171.89:2379,100.126.122.28:2379

# Generate real values with:
# openssl rand -base64 32
POSTGRES_SUPERUSER_PASSWORD=replace-me
POSTGRES_REPLICATION_PASSWORD=replace-me
POSTGRES_REWIND_PASSWORD=replace-me
