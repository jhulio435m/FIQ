# Copy to .env on each node. Do not commit real .env files.

# Node identity. Use one of:
# - oti: NODE_ID=1, ETCD_NAME=etcd-1, PATRONI_NAME=oti, NODE_IP=10.77.0.2
# - ubuntu: NODE_ID=2, ETCD_NAME=etcd-2, PATRONI_NAME=ubuntu, NODE_IP=10.77.0.1
# - laptop: NODE_ID=3, ETCD_NAME=etcd-3, PATRONI_NAME=laptop, NODE_IP=10.77.0.3
NODE_ID=1
NODE_IP=10.77.0.2
ETCD_NAME=etcd-1
PATRONI_NAME=oti

# Cluster node addresses over the private network used by PostgreSQL HA.
NODE1_IP=10.77.0.2
NODE2_IP=10.77.0.1
NODE3_IP=10.77.0.3

ETCD_INITIAL_CLUSTER_TOKEN=fiq-etcd-cluster
ETCD_INITIAL_CLUSTER=etcd-1=http://10.77.0.2:2380,etcd-2=http://10.77.0.1:2380,etcd-3=http://10.77.0.3:2380
ETCD_INITIAL_CLUSTER_STATE=new
PATRONI_ETCD_HOSTS=10.77.0.2:2379,10.77.0.1:2379,10.77.0.3:2379

# Generate real values with:
# openssl rand -base64 32
POSTGRES_SUPERUSER_PASSWORD=replace-me
POSTGRES_REPLICATION_PASSWORD=replace-me
POSTGRES_REWIND_PASSWORD=replace-me
