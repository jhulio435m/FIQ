# Copy to /etc/fiq-watcher/watcher.env on the watcher host.
# Do not commit real production domains, API keys, or webhook URLs.

FIQ_WATCHER_TARGETS="frontend=https://fiq.example.edu.pe grafana=https://grafana.example.edu.pe/api/health api_health=https://fiq.example.edu.pe/health powerbi_dashboard=https://fiq.example.edu.pe/reports/public/dashboard-data"
# Use only hosts reachable from the watcher network.
FIQ_WATCHER_TCP_TARGETS="azure_ssh=147.224.242.204:22"
FIQ_WATCHER_TIMEOUT_SECONDS=10
FIQ_WATCHER_METRICS_FILE=/var/lib/fiq-watcher/fiq-watcher.prom
FIQ_WATCHER_LOG_FILE=/var/log/fiq-watcher/watcher.log
FIQ_WATCHER_STATE_DIR=/var/lib/fiq-watcher
FIQ_WATCHER_ALERT_ON_RECOVERY=true

# Required only for /reports/public/* endpoints.
DASHBOARD_API_KEY=replace-in-server

# Optional: Slack, Discord, ntfy, Gotify, or another webhook that accepts {"text":"..."}.
FIQ_WATCHER_ALERT_WEBHOOK_URL=

# Optional Telegram alerts and /status bot. Store the real token only on the server.
# If TELEGRAM_ALLOWED_CHAT_IDS is empty, the first chat that sends /start or /status is registered.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=
TELEGRAM_CHATS_FILE=/var/lib/fiq-watcher/telegram_chats
TELEGRAM_OFFSET_FILE=/var/lib/fiq-watcher/telegram_offset
