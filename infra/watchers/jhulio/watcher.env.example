# Copy to /etc/fiq-watcher/watcher.env on the watcher host.
# Do not commit real production domains, API keys, or webhook URLs.

FIQ_WATCHER_TARGETS="api_health=https://fiq.example.edu.pe/health powerbi_dashboard=https://fiq.example.edu.pe/reports/public/dashboard-data"
FIQ_WATCHER_TIMEOUT_SECONDS=10
FIQ_WATCHER_METRICS_FILE=/var/lib/fiq-watcher/fiq-watcher.prom
FIQ_WATCHER_LOG_FILE=/var/log/fiq-watcher/watcher.log

# Required only for /reports/public/* endpoints.
DASHBOARD_API_KEY=replace-in-server

# Optional: Slack, Discord, ntfy, Gotify, or another webhook that accepts {"text":"..."}.
FIQ_WATCHER_ALERT_WEBHOOK_URL=
